<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <remote
        name="github-yocto"
        fetch="https://github.com/yoctoproject" />
    <remote
        name="git-yocto"
        fetch="https://git.yoctoproject.org" />
    <remote
        name="oe"
        fetch="https://git.openembedded.org" />
    <remote
        name="git-kraj"
        fetch="https://github.com/kraj" />

    <remote
        name="practice-yocto"
        fetch="https://github.com/practice-yocto" />
    <default
        revision="main"
        remote="practice-yocto"
        sync-j="8" />

    <!-- yocto projects -->
    <project path="poky" name="poky" remote="github-yocto" revision="scarthgap" />
    <project path="layers/meta-openembedded" name="meta-openembedded" remote="oe" revision="scarthgap" />
    <project path="layers/meta-selinux" name="meta-selinux" remote="git-yocto" revision="scarthgap" />
    <project path="layers/meta-clang" name="meta-clang" remote="git-kraj" revision="scarthgap" />
    <!-- end yocto projects -->

    <!-- practice projects -->
    <project path="layers/layer-core" name="layer-core" revision="main">
        <linkfile src="envsetup.sh" dest="envsetup.sh" />
        <linkfile src=".gitignore" dest=".gitignore" />
        <linkfile src="README.md" dest="README.md" />
        <linkfile src="settings.json" dest=".vscode/settings.json" />
    </project>

    <project path="external/linux" name="linux" revision="main" />
    <project path="external/hello-kmodule" name="hello-kmodule" revision="main" />
    <project path="external/hello-app" name="hello-app" revision="main" />
    <project path="external/hello-lib" name="hello-lib" revision="main" />
    <project path="external/use-hello-lib" name="use-hello-lib" revision="main" />
    <project path="external/hello-sdk-app" name="hello-sdk-app" revision="main" />
    <project path="external/hello-sdk-kmodule" name="hello-sdk-kmodule" revision="main" />
    <!-- end practice projects -->
</manifest>
